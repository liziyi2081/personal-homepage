---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import MagneticCard from '../../components/MagneticCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const allTags = [...new Set(articles.flatMap((a: any) => a.data.tags))];
const selectedTag = Astro.url.searchParams.get('tag');
const filteredArticles = selectedTag
  ? articles.filter((a) => a.data.tags.includes(selectedTag))
  : articles;
---

<BaseLayout>
  <main class="max-w-6xl mx-auto px-6 lg:px-12 py-20">
    <p class="font-mono text-sm text-neon-cyan mb-2">$ ls articles/</p>
    <h1 class="font-display text-4xl md:text-5xl font-bold text-plasma mb-12">Articles</h1>

    {
      allTags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-12">
          <a
            href="/articles"
            class={`font-mono text-xs tracking-wider uppercase px-4 py-1.5 border transition-colors duration-200 ${
              !selectedTag ? 'border-neon-cyan text-neon-cyan' : 'border-white/10 text-frost hover:border-white/20'
            }`}
          >
            All
          </a>
          {allTags.map((tag: string) => (
            <a
              href={`/articles?tag=${tag}`}
              class={`font-mono text-xs tracking-wider uppercase px-4 py-1.5 border transition-colors duration-200 ${
                selectedTag === tag ? 'border-neon-cyan text-neon-cyan' : 'border-white/10 text-frost hover:border-white/20'
              }`}
            >
              {tag}
            </a>
          ))}
        </div>
      )
    }

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {filteredArticles.length > 0 ? (
        filteredArticles.map((article) => (
          <MagneticCard class="glass-card">
            <a
              href={`/articles/${article.slug}`}
              class="group block p-6"
            >
              <p class="font-mono text-xs text-frost/50 mb-3">
                {article.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </p>
              <h2 class="font-display text-lg font-bold text-plasma mb-2 group-hover:text-neon-cyan transition-colors duration-200">
                {article.data.title}
              </h2>
              <p class="font-body text-sm text-frost leading-relaxed mb-4">
                {article.data.description}
              </p>
              <div class="flex flex-wrap gap-2">
                {article.data.tags.map((tag: string) => (
                  <span class="font-mono text-[10px] tracking-wider uppercase text-frost/40 border border-white/10 px-2 py-0.5">
                    {tag}
                  </span>
                ))}
              </div>
            </a>
          </MagneticCard>
        ))
      ) : (
        <p class="col-span-full text-center font-mono text-sm text-frost/40 py-12">
          {selectedTag ? `No articles tagged "${selectedTag}".` : 'No articles yet.'}
        </p>
      )}
    </div>
  </main>
  <Footer />
</BaseLayout>
