---
import { getCollection } from 'astro:content';
import { statSync } from 'node:fs';
import { resolve } from 'node:path';
import Footer from '../../components/Footer.astro';
import MagneticCard from '../../components/MagneticCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const contentDir = resolve(process.cwd(), 'src/content');

function getMtime(id: string): number {
  return statSync(resolve(contentDir, 'articles', id)).mtimeMs;
}

function getFileDates(id: string): { created: string; updated: string } {
  const filePath = resolve(contentDir, 'articles', id);
  const stat = statSync(filePath);
  return { created: fmtDate(stat.birthtime), updated: fmtDate(stat.mtime) };
}

function fmtDate(d: Date): string {
  const y = d.getFullYear();
  const mo = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  const h = String(d.getHours()).padStart(2, '0');
  const mi = String(d.getMinutes()).padStart(2, '0');
  const s = String(d.getSeconds()).padStart(2, '0');
  return `${y}-${mo}-${day} ${h}:${mi}:${s}`;
}

const allArticles = (await getCollection('articles')).sort(
  (a, b) => getMtime(b.id) - getMtime(a.id)
);

const perPage = 5;
const totalPages = Math.ceil(allArticles.length / perPage);
const currentPage = Math.max(1, Math.min(totalPages, Number(Astro.url.searchParams.get('page')) || 1));
const start = (currentPage - 1) * perPage;
const articles = allArticles.slice(start, start + perPage);
const base = import.meta.env.BASE_URL;
---

<BaseLayout>
  <main class="max-w-6xl mx-auto px-6 lg:px-12 py-20">
    <p class="font-mono text-sm text-neon-cyan mb-2">$ ls articles/ --latest</p>
    <h1 class="font-display text-4xl md:text-5xl font-bold text-plasma mb-12">Articles</h1>

    <div class="grid grid-cols-1 gap-4">
      {articles.length > 0 ? (
        articles.map((article) => {
          const dates = getFileDates(article.id);
          return (
          <MagneticCard class="glass-card">
            <a href={`${base}/articles/${article.slug}`} class="group block p-6 h-full flex flex-col">
              <p class="font-mono text-xs text-frost/50 mb-3 shrink-0">
                created {dates.created} / updated {dates.updated}
              </p>
              <h2 class="font-display text-lg font-bold text-plasma mb-2 group-hover:text-neon-cyan transition-colors duration-200 truncate shrink-0">
                {article.data.title}
              </h2>
              <p class="font-body text-sm text-frost leading-relaxed line-clamp-2 overflow-hidden min-h-0">
                {article.data.description}
              </p>
            </a>
          </MagneticCard>
          );
        })
      ) : (
        <p class="col-span-full text-center font-mono text-sm text-frost/40 py-12">
          No articles yet.
        </p>
      )}
    </div>

    {totalPages > 1 && (
      <nav class="flex items-center justify-center gap-4 mt-12 font-mono text-sm">
        {currentPage > 1 ? (
          <a href={`${base}/articles?page=${currentPage - 1}`} class="text-frost hover:text-plasma transition-colors duration-200">
            &larr; Prev
          </a>
        ) : (
          <span class="text-frost/20">&larr; Prev</span>
        )}
        <span class="text-frost/50">
          {currentPage} / {totalPages}
        </span>
        {currentPage < totalPages ? (
          <a href={`${base}/articles?page=${currentPage + 1}`} class="text-frost hover:text-plasma transition-colors duration-200">
            Next &rarr;
          </a>
        ) : (
          <span class="text-frost/20">Next &rarr;</span>
        )}
      </nav>
    )}

    <div class="mt-12">
      <a href={base} class="font-mono text-xs text-frost hover:text-plasma transition-colors duration-200">
        &larr; 回到首页
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>
