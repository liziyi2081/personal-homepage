---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import MagneticCard from '../components/MagneticCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<BaseLayout>
  <main class="max-w-4xl mx-auto px-6 lg:px-12 py-20">
    <p class="font-mono text-sm text-neon-cyan mb-2">$ ls projects/</p>
    <h1 class="font-display text-4xl md:text-5xl font-bold text-plasma mb-12">
      Projects
    </h1>

    <div class="space-y-6">
      {projects.length > 0 ? (
        projects.map((project, i) => (
          <MagneticCard class="glass-card block">
            <a
              href={project.data.repo}
              target="_blank"
              rel="noopener noreferrer"
              class="group block p-6"
            >
              <div class="flex items-start gap-6">
                <span class="font-mono text-xs text-frost/30 mt-1 w-6">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <div class="hex-icon w-16 h-16 flex-shrink-0 border border-white/10">
                  <span class="font-mono text-xl font-bold text-neon-cyan">
                    {project.data.name[0]}
                  </span>
                </div>
                <div class="min-w-0 flex-1">
                  <div class="flex items-center gap-3 mb-2">
                    <h2 class="font-display text-xl font-bold text-plasma group-hover:text-neon-cyan transition-colors duration-200">
                      {project.data.name}
                    </h2>
                    {project.data.language && (
                      <span class="font-mono text-[11px] text-frost/30">
                        {project.data.language}
                      </span>
                    )}
                    {project.data.stars > 0 && (
                      <span class="font-mono text-[11px] text-frost/30">
                        {project.data.stars} &star;
                      </span>
                    )}
                  </div>
                  <p class="font-body text-frost leading-relaxed mb-3">
                    {project.data.description}
                  </p>
                  <p class="font-mono text-xs text-frost/20 truncate">
                    {project.data.repo}
                  </p>
                </div>
                <span class="font-mono text-xs text-frost/30 group-hover:text-neon-cyan transition-colors duration-200 mt-1">
                  &nearr;
                </span>
              </div>
            </a>
          </MagneticCard>
        ))
      ) : (
        <p class="font-mono text-sm text-frost/40 text-center py-12">
          No projects yet. Add yours in <code class="text-frost/60">src/content/projects/</code>.
        </p>
      )}
    </div>
  </main>
  <Footer />
</BaseLayout>
