---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const products = (await getCollection('products')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout>
  <Header />
  <main class="max-w-4xl mx-auto px-6 lg:px-12 py-20">
    <p class="font-mono text-sm text-forge-orange mb-2">$ ls products/</p>
    <h1 class="font-display text-4xl md:text-5xl font-bold text-parchment mb-12">
      Products
    </h1>

    <div class="space-y-6">
      {products.length > 0 ? (
        products.map((product, i) => (
          <div id={product.slug}>
            <a
              href={product.data.link}
              target="_blank"
              rel="noopener noreferrer"
              class="group block border border-stone/20 bg-anvil-grey hover:border-forge-orange transition-colors duration-200 p-6"
            >
              <div class="flex items-start gap-6">
                <span class="font-mono text-xs text-stone/40 mt-1 w-6">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <div class="w-14 h-14 flex-shrink-0 bg-iron-black border border-stone/20 flex items-center justify-center">
                  <span class="font-display text-xl font-bold text-stone">
                    {product.data.name[0]}
                  </span>
                </div>
                <div class="min-w-0 flex-1">
                  <h2 class="font-display text-xl font-bold text-parchment group-hover:text-forge-orange transition-colors duration-200 mb-2">
                    {product.data.name}
                  </h2>
                  <p class="font-body text-stone leading-relaxed">
                    {product.data.description}
                  </p>
                </div>
                <span class="font-mono text-xs text-stone/40 group-hover:text-forge-orange transition-colors duration-200 mt-1">
                  &nearr;
                </span>
              </div>
            </a>
          </div>
        ))
      ) : (
        <p class="font-mono text-sm text-stone/50 text-center py-12">
          No products yet. Add yours in <code class="text-stone/70">src/content/products/</code>.
        </p>
      )}
    </div>
  </main>
  <Footer />
</BaseLayout>
