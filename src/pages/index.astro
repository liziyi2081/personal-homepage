---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const about = await getCollection('about');
const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const products = await getCollection('products');
const projects = await getCollection('projects');
const profile = about[0]?.data;
---

<BaseLayout>
  <Header />

  <main class="max-w-6xl mx-auto px-6 lg:px-12">
    <!-- Hero: signature $ whoami -->
    <section class="py-24 md:py-36">
      <p class="font-mono text-sm text-forge-orange mb-4 animate-fade-in tracking-wide">
        $ whoami
      </p>
      {
        profile && (
          <>
            <h1 class="font-display text-5xl md:text-7xl font-bold text-parchment leading-tight mb-6">
              {profile.nickname}
            </h1>
            <p class="font-body text-xl md:text-2xl text-stone leading-relaxed max-w-2xl italic">
              {profile.tagline}
            </p>
            <p class="mt-6 font-body text-base text-stone/70 max-w-xl leading-relaxed">
              {profile.bio}
            </p>
          </>
        )
      }
    </section>

    <hr class="border-stone/20" />

    <!-- Featured Articles -->
    <section class="py-20">
      <div class="flex items-center justify-between mb-10">
        <h2 class="font-mono text-xs tracking-[0.2em] uppercase text-stone">
          Featured
        </h2>
        <a
          href="/articles"
          class="font-mono text-xs text-stone hover:text-parchment transition-colors duration-200"
        >
          View all &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-stone/20">
        <div class="bg-iron-black"></div>
        {
          articles.length > 0 ? (
            articles.map((article) => (
              <a
                href={`/articles/${article.slug}`}
                class="group block border border-stone/20 bg-iron-black hover:border-forge-orange transition-colors duration-200 p-6"
              >
                <p class="font-mono text-xs text-stone/60 mb-3">
                  {article.data.date.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </p>
                <h3 class="font-display text-lg font-bold text-parchment mb-2 group-hover:text-forge-orange transition-colors duration-200">
                  {article.data.title}
                </h3>
                <p class="font-body text-sm text-stone leading-relaxed mb-4">
                  {article.data.description}
                </p>
                <div class="flex flex-wrap gap-2">
                  {article.data.tags.map((tag) => (
                    <span class="font-mono text-[10px] tracking-wider uppercase text-stone/50 border border-stone/20 px-2 py-0.5">
                      {tag}
                    </span>
                  ))}
                </div>
              </a>
            ))
          ) : (
            <div class="col-span-3 border border-stone/20 bg-iron-black p-6 text-center font-mono text-xs text-stone/50">
              No articles yet. Write your first post in <code class="text-stone/70">src/content/articles/</code>.
            </div>
          )
        }
      </div>
    </section>

    <!-- Products + Projects summary row -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pb-24">
      <!-- Products -->
      <section>
        <div class="flex items-center justify-between mb-8">
          <h2 class="font-mono text-xs tracking-[0.2em] uppercase text-stone">
            Products
          </h2>
          <a
            href="/products"
            class="font-mono text-xs text-stone hover:text-parchment transition-colors duration-200"
          >
            View all &rarr;
          </a>
        </div>
        <div class="space-y-4">
          {products.length > 0 ? (
            products.map((product) => (
              <a
                href={`/products#${product.slug}`}
                class="block border border-stone/20 bg-anvil-grey hover:border-forge-orange transition-colors duration-200 p-5"
              >
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 flex-shrink-0 bg-stone/10 flex items-center justify-center">
                    <span class="font-display text-xs font-bold text-stone">{product.data.name[0]}</span>
                  </div>
                  <div class="min-w-0">
                    <h3 class="font-display text-sm font-bold text-parchment">{product.data.name}</h3>
                    <p class="font-body text-xs text-stone/70 truncate">{product.data.description}</p>
                  </div>
                  <span class="ml-auto font-mono text-[10px] text-stone/40">&nearr;</span>
                </div>
              </a>
            ))
          ) : (
            <p class="font-mono text-xs text-stone/50 py-4 text-center">No products yet.</p>
          )}
        </div>
      </section>

      <!-- Projects -->
      <section>
        <div class="flex items-center justify-between mb-8">
          <h2 class="font-mono text-xs tracking-[0.2em] uppercase text-stone">
            Projects
          </h2>
          <a
            href="/projects"
            class="font-mono text-xs text-stone hover:text-parchment transition-colors duration-200"
          >
            View all &rarr;
          </a>
        </div>
        <div class="space-y-4">
          {projects.length > 0 ? (
            projects.map((project) => (
              <a
                href={project.data.repo}
                target="_blank"
                rel="noopener noreferrer"
                class="block border border-stone/20 bg-anvil-grey hover:border-forge-orange transition-colors duration-200 p-5"
              >
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 flex-shrink-0 bg-stone/10 flex items-center justify-center">
                    <span class="font-display text-xs font-bold text-stone">{project.data.name[0]}</span>
                  </div>
                  <div class="min-w-0">
                    <div class="flex items-center gap-2">
                      <h3 class="font-display text-sm font-bold text-parchment">{project.data.name}</h3>
                      {project.data.language && (
                        <span class="font-mono text-[10px] text-stone/40">{project.data.language}</span>
                      )}
                    </div>
                    <p class="font-body text-xs text-stone/70 truncate">{project.data.description}</p>
                  </div>
                  <span class="ml-auto font-mono text-[10px] text-stone/40">&nearr;</span>
                </div>
              </a>
            ))
          ) : (
            <p class="font-mono text-xs text-stone/50 py-4 text-center">No projects yet.</p>
          )}
        </div>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>
