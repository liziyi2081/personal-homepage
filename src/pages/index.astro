---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MagneticCard from '../components/MagneticCard.astro';
import StatCard from '../components/StatCard.astro';
import { getCollection } from 'astro:content';

const about = await getCollection('about');
const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const allArticles = await getCollection('articles');
const products = await getCollection('products');
const projects = await getCollection('projects');
const outsourcings = await getCollection('outsourcing');
const profile = about[0]?.data;
---

<BaseLayout>
  <Header />

  <main class="max-w-6xl mx-auto px-6 lg:px-12">
    <!-- Hero -->
    <section class="py-24 md:py-36">
      <p class="font-mono text-sm text-neon-cyan mb-4 tracking-wide">
        <span id="typewriter"></span><span class="cursor-blink text-neon-cyan">█</span>
      </p>
      {
        profile && (
          <>
            <h1 class="font-display text-5xl md:text-7xl font-bold leading-tight mb-6 text-gradient">
              {profile.nickname}
            </h1>
            <p class="font-body text-xl md:text-2xl text-frost leading-relaxed max-w-2xl italic">
              {profile.tagline}
            </p>
            <p class="mt-6 font-body text-base text-frost/70 max-w-xl leading-relaxed">
              {profile.bio}
            </p>
          </>
        )
      }

      <!-- Stat cards -->
      <div class="mt-12 grid grid-cols-2 md:grid-cols-4 gap-4">
        <StatCard value={products.length} label="Products" path="products" prefix="P" />
        <StatCard value={allArticles.length} label="Articles" path="articles" prefix="A" />
        <StatCard value={projects.length} label="Open Source" path="projects" prefix="OS" />
        <StatCard value={outsourcings.length} label="Contracts" path="outsourcing" prefix="CT" />
      </div>
    </section>

    <hr class="border-white/5" />

    <!-- 2×2 Content Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pb-24 py-20">

      <!-- Articles -->
      <section>
        <div class="flex items-center justify-between mb-6">
          <h2 class="font-mono text-xs tracking-[0.2em] uppercase text-frost">
            <span class="text-neon-cyan">$</span> ls articles/ --latest
          </h2>
          <a href="/articles" class="font-mono text-xs text-frost hover:text-plasma transition-colors duration-200">
            View all &rarr;
          </a>
        </div>
        <div class="space-y-4">
          {articles.length > 0 ? (
            articles.slice(0, 2).map((article) => (
              <MagneticCard class="glass-card">
                <a href={`/articles/${article.slug}`} class="group block p-6">
                  <p class="font-mono text-xs text-frost/50 mb-3">
                    {article.data.date.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric',
                    })}
                  </p>
                  <h3 class="font-display text-lg font-bold text-plasma mb-2 group-hover:text-neon-cyan transition-colors duration-200">
                    {article.data.title}
                  </h3>
                  <p class="font-body text-sm text-frost leading-relaxed mb-4">
                    {article.data.description}
                  </p>
                  <div class="flex flex-wrap gap-2">
                    {article.data.tags.map((tag) => (
                      <span class="font-mono text-[10px] tracking-wider uppercase text-frost/40 border border-white/10 px-2 py-0.5">
                        {tag}
                      </span>
                    ))}
                  </div>
                </a>
              </MagneticCard>
            ))
          ) : (
            <div class="glass-card p-6 text-center font-mono text-xs text-frost/40">
              No articles yet.
            </div>
          )}
        </div>
      </section>

      <!-- Products -->
      <section>
        <div class="flex items-center justify-between mb-6">
          <h2 class="font-mono text-xs tracking-[0.2em] uppercase text-frost">
            <span class="text-neon-cyan">$</span> cat products.json | jq '.[]'
          </h2>
          <a href="/products" class="font-mono text-xs text-frost hover:text-plasma transition-colors duration-200">
            View all &rarr;
          </a>
        </div>
        <div class="space-y-4">
          {products.length > 0 ? (
            products.slice(0, 2).map((product) => (
              <MagneticCard class="glass-card">
                <a href={`/products#${product.slug}`} class="group block p-6">
                  <h3 class="font-display text-lg font-bold text-plasma mb-2 group-hover:text-neon-cyan transition-colors duration-200">
                    {product.data.name}
                  </h3>
                  <p class="font-body text-sm text-frost leading-relaxed mb-4">
                    {product.data.description}
                  </p>
                  <div class="flex items-center gap-2 font-mono text-xs text-frost/40">
                    <span>&rarr;</span>
                    <span class="truncate">{product.data.link}</span>
                  </div>
                </a>
              </MagneticCard>
            ))
          ) : (
            <div class="glass-card p-6 text-center font-mono text-xs text-frost/40">
              No products yet.
            </div>
          )}
        </div>
      </section>

      <!-- Open Source -->
      <section>
        <div class="flex items-center justify-between mb-6">
          <h2 class="font-mono text-xs tracking-[0.2em] uppercase text-frost">
            <span class="text-neon-cyan">$</span> gh repo list --limit 3
          </h2>
          <a href="/projects" class="font-mono text-xs text-frost hover:text-plasma transition-colors duration-200">
            View all &rarr;
          </a>
        </div>
        <div class="space-y-4">
          {projects.length > 0 ? (
            projects.slice(0, 2).map((project) => (
              <MagneticCard class="glass-card">
                <a href={project.data.repo} target="_blank" rel="noopener noreferrer" class="group block p-6">
                  <p class="font-mono text-xs text-frost/50 mb-3">
                    {project.data.name}
                    {project.data.language && (
                      <span> &middot; <span class="text-neon-cyan/60">{project.data.language}</span></span>
                    )}
                  </p>
                  <h3 class="font-display text-lg font-bold text-plasma mb-2 group-hover:text-neon-cyan transition-colors duration-200">
                    {project.data.description}
                  </h3>
                  <div class="flex items-center gap-2 font-mono text-xs text-frost/40">
                    <span class="text-neon-cyan/60">&star; {project.data.stars}</span>
                    <span>&rarr; repo</span>
                  </div>
                </a>
              </MagneticCard>
            ))
          ) : (
            <div class="glass-card p-6 text-center font-mono text-xs text-frost/40">
              No projects yet.
            </div>
          )}
        </div>
      </section>

      <!-- Contracts -->
      <section>
        <div class="flex items-center justify-between mb-6">
          <h2 class="font-mono text-xs tracking-[0.2em] uppercase text-frost">
            <span class="text-neon-cyan">$</span> ls outsourcing/ --reverse
          </h2>
          <a href="/projects" class="font-mono text-xs text-frost hover:text-plasma transition-colors duration-200">
            View all &rarr;
          </a>
        </div>
        <div class="space-y-4">
          {outsourcings.length > 0 ? (
            outsourcings.slice(0, 2).map((item) => (
              <MagneticCard class="glass-card">
                <a href={item.data.link || '#'} class="group block p-6">
                  <p class="font-mono text-xs text-frost/50 mb-3">
                    {item.data.name}
                    {item.data.client && (
                      <span> &middot; <span class="text-neon-cyan/60">{item.data.client}</span></span>
                    )}
                  </p>
                  <h3 class="font-display text-lg font-bold text-plasma mb-2 group-hover:text-neon-cyan transition-colors duration-200">
                    {item.data.description}
                  </h3>
                  {item.data.link && (
                    <div class="flex items-center gap-2 font-mono text-xs text-frost/40">
                      <span>&rarr;</span>
                      <span class="truncate">{item.data.link}</span>
                    </div>
                  )}
                </a>
              </MagneticCard>
            ))
          ) : (
            <div class="glass-card p-6 text-center font-mono text-xs text-frost/40">
              No contracts yet.
            </div>
          )}
        </div>
      </section>

    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  (function() {
    var el = document.getElementById('typewriter');
    if (!el) return;
    var texts = [
      '$ whoami',
      '$ cat /etc/motd',
      '$ echo $USER',
      '$ uname -a',
    ];
    var i = 0;
    var j = 0;
    var typing = true;
    var pauseEnd = 0;

    function tick() {
      var now = Date.now();
      if (!typing && now < pauseEnd) {
        requestAnimationFrame(tick);
        return;
      }

      var current = texts[i % texts.length];

      if (typing) {
        if (j <= current.length) {
          el.textContent = current.substring(0, j);
          j++;
          setTimeout(tick, 60 + Math.random() * 40);
          return;
        }
        // finished typing, pause then delete
        typing = false;
        pauseEnd = now + 2000;
        requestAnimationFrame(tick);
      } else {
        if (j > 0) {
          j--;
          el.textContent = current.substring(0, j);
          setTimeout(tick, 25 + Math.random() * 20);
          return;
        }
        // finished deleting, next text
        typing = true;
        i++;
        j = 0;
        setTimeout(tick, 150);
      }
    }

    tick();
  })();
</script>
