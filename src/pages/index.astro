---
import { statSync } from 'node:fs';
import { resolve } from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import MagneticCard from '../components/MagneticCard.astro';
import StatCard from '../components/StatCard.astro';
import { getCollection } from 'astro:content';

const about = await getCollection('about');
const allArticles = await getCollection('articles');
const articles = allArticles
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const products = await getCollection('products');
const projects = await getCollection('projects');
const outsourcings = await getCollection('outsourcing');
const profile = about[0]?.data;
const base = import.meta.env.BASE_URL;

function fmtDate(d: Date): string {
  return d.toISOString().split('T')[0];
}

const contentDir = resolve(process.cwd(), 'src/content');

function getFileDates(collection: string, id: string): { created: string; updated: string } {
  const filePath = resolve(contentDir, collection, id);
  const stat = statSync(filePath);
  return {
    created: fmtDate(stat.birthtime),
    updated: fmtDate(stat.mtime),
  };
}

interface CardItem {
  title: string;
  description: string;
  created: string;
  updated: string;
  link: string;
}

const productCards: CardItem[] = products[0]
  ? [{ title: products[0].data.name, description: products[0].data.description, created: getFileDates('products', products[0].id).created, updated: getFileDates('products', products[0].id).updated, link: `${base}/products/${products[0].slug}` }]
  : [];

const articleCards: CardItem[] = articles[0]
  ? [{ title: articles[0].data.title, description: articles[0].data.description, created: getFileDates('articles', articles[0].id).created, updated: getFileDates('articles', articles[0].id).updated, link: `${base}/articles/${articles[0].slug}` }]
  : [];

const projectCards: CardItem[] = projects[0]
  ? [{ title: projects[0].data.name, description: projects[0].data.description, created: getFileDates('projects', projects[0].id).created, updated: getFileDates('projects', projects[0].id).updated, link: `${base}/projects/${projects[0].slug}` }]
  : [];

const outsourcingCards: CardItem[] = outsourcings[0]
  ? [{ title: outsourcings[0].data.name, description: outsourcings[0].data.description, created: getFileDates('outsourcing', outsourcings[0].id).created, updated: getFileDates('outsourcing', outsourcings[0].id).updated, link: `${base}/outsourcing/${outsourcings[0].slug}` }]
  : [];
---

<BaseLayout>

  <main class="max-w-6xl mx-auto px-6 lg:px-12">
    <!-- Hero -->
    <section class="py-24 md:py-36">
      <p class="font-mono text-sm text-neon-cyan mb-4 tracking-wide">
        <span id="typewriter"></span><span class="cursor-blink text-neon-cyan">█</span>
      </p>
      {
        profile && (
          <>
            <div class="mb-8">
              <div class="flex items-center gap-12 mb-6">
                <h1 class="font-display text-5xl md:text-7xl font-bold leading-tight text-gradient">
                  {profile.nickname}
                </h1>
                {profile.avatar && (
                  <img src={profile.avatar} alt={profile.nickname} class="w-24 h-24 rounded-2xl border border-white/10 object-cover flex-shrink-0" />
                )}
              </div>
              <p class="font-body text-xl md:text-2xl text-frost leading-relaxed italic">
                {profile.tagline}
              </p>
            </div>
            <p class="font-body text-base text-frost/70 max-w-xl leading-relaxed">
              {profile.bio}
            </p>
            <div class="mt-6 space-y-1.5 font-mono text-xs">
              <p class="text-frost/50">
                <span class="text-neon-cyan">$</span> <span class="text-frost/30">cat</span> /etc/profile
              </p>
              <div class="glass-card p-4 space-y-1.5 inline-block">
                <p class="text-plasma"><span class="text-frost/30">school</span>    = &quot;{profile.school || '...'}&quot;</p>
                <p class="text-plasma"><span class="text-frost/30">hometown</span>  = &quot;{profile.hometown || '...'}&quot;</p>
                <p class="text-plasma"><span class="text-frost/30">location</span>  = &quot;{profile.location || '...'}&quot;</p>
              </div>
            </div>
          </>
        )
      }

      <!-- Stat cards: Products → Articles → Open Source → Outsourcing -->
      <div class="mt-12 grid grid-cols-2 md:grid-cols-4 gap-4">
        <StatCard value={products.length} label="Products" path="products" prefix="P" />
        <StatCard value={allArticles.length} label="Articles" path="articles" prefix="A" />
        <StatCard value={projects.length} label="Open Source" path="projects" prefix="OS" />
        <StatCard value={outsourcings.length} label="Outsourcing" path="outsourcing" prefix="CT" />
      </div>
    </section>

    <hr class="border-white/5" />

    <!-- 2×2 Content Grid: Products | Articles / Open Source | Outsourcing -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pb-24 py-20" style="grid-template-rows: 1fr 1fr;">

      <!-- Products -->
      <section class="flex flex-col">
        <div class="flex items-center justify-between mb-6 shrink-0">
          <h2 class="font-mono text-xs tracking-[0.2em] uppercase text-frost">
            <span class="text-neon-cyan">$</span> cat products.json | jq '.[]'
          </h2>
          <a href={`${base}/products`} class="font-mono text-xs text-frost hover:text-plasma transition-colors duration-200">
            View all &rarr;
          </a>
        </div>
        <div class="flex-1 flex flex-col gap-4 min-h-0">
          {productCards.length > 0 ? (
            productCards.map((card) => (
              <MagneticCard class="glass-card flex-1">
                <a href={card.link} class="group block p-6 h-full flex flex-col">
                  <p class="font-mono text-xs text-frost/50 mb-3 shrink-0">
                    created {card.created} / updated {card.updated}
                  </p>
                  <h3 class="font-display text-lg font-bold text-plasma mb-2 group-hover:text-neon-cyan transition-colors duration-200 truncate shrink-0">
                    {card.title}
                  </h3>
                  <p class="font-body text-sm text-frost leading-relaxed line-clamp-2 overflow-hidden min-h-0">
                    {card.description}
                  </p>
                </a>
              </MagneticCard>
            ))
          ) : (
            <div class="glass-card p-6 h-full flex flex-col">
              <p class="font-mono text-xs text-frost/50 mb-3 shrink-0">
                created NULL / updated NULL
              </p>
              <h3 class="font-display text-lg font-bold text-frost/40 mb-2 truncate shrink-0">
                NULL
              </h3>
              <p class="font-body text-sm text-frost/40 leading-relaxed line-clamp-2 overflow-hidden min-h-0">
                NULL
              </p>
            </div>
          )}
        </div>
      </section>

      <!-- Articles -->
      <section class="flex flex-col">
        <div class="flex items-center justify-between mb-6 shrink-0">
          <h2 class="font-mono text-xs tracking-[0.2em] uppercase text-frost">
            <span class="text-neon-cyan">$</span> ls articles/ --latest
          </h2>
          <a href={`${base}/articles`} class="font-mono text-xs text-frost hover:text-plasma transition-colors duration-200">
            View all &rarr;
          </a>
        </div>
        <div class="flex-1 flex flex-col gap-4 min-h-0">
          {articleCards.length > 0 ? (
            articleCards.map((card) => (
              <MagneticCard class="glass-card flex-1">
                <a href={card.link} class="group block p-6 h-full flex flex-col">
                  <p class="font-mono text-xs text-frost/50 mb-3 shrink-0">
                    created {card.created} / updated {card.updated}
                  </p>
                  <h3 class="font-display text-lg font-bold text-plasma mb-2 group-hover:text-neon-cyan transition-colors duration-200 truncate shrink-0">
                    {card.title}
                  </h3>
                  <p class="font-body text-sm text-frost leading-relaxed line-clamp-2 overflow-hidden min-h-0">
                    {card.description}
                  </p>
                </a>
              </MagneticCard>
            ))
          ) : (
            <div class="glass-card p-6 h-full flex flex-col">
              <p class="font-mono text-xs text-frost/50 mb-3 shrink-0">
                created NULL / updated NULL
              </p>
              <h3 class="font-display text-lg font-bold text-frost/40 mb-2 truncate shrink-0">
                NULL
              </h3>
              <p class="font-body text-sm text-frost/40 leading-relaxed line-clamp-2 overflow-hidden min-h-0">
                NULL
              </p>
            </div>
          )}
        </div>
      </section>

      <!-- Open Source -->
      <section class="flex flex-col">
        <div class="flex items-center justify-between mb-6 shrink-0">
          <h2 class="font-mono text-xs tracking-[0.2em] uppercase text-frost">
            <span class="text-neon-cyan">$</span> gh repo list --limit 3
          </h2>
          <a href={`${base}/projects`} class="font-mono text-xs text-frost hover:text-plasma transition-colors duration-200">
            View all &rarr;
          </a>
        </div>
        <div class="flex-1 flex flex-col gap-4 min-h-0">
          {projectCards.length > 0 ? (
            projectCards.map((card) => (
              <MagneticCard class="glass-card flex-1">
                <a href={card.link} class="group block p-6 h-full flex flex-col">
                  <p class="font-mono text-xs text-frost/50 mb-3 shrink-0">
                    created {card.created} / updated {card.updated}
                  </p>
                  <h3 class="font-display text-lg font-bold text-plasma mb-2 group-hover:text-neon-cyan transition-colors duration-200 truncate shrink-0">
                    {card.title}
                  </h3>
                  <p class="font-body text-sm text-frost leading-relaxed line-clamp-2 overflow-hidden min-h-0">
                    {card.description}
                  </p>
                </a>
              </MagneticCard>
            ))
          ) : (
            <div class="glass-card p-6 h-full flex flex-col">
              <p class="font-mono text-xs text-frost/50 mb-3 shrink-0">
                created NULL / updated NULL
              </p>
              <h3 class="font-display text-lg font-bold text-frost/40 mb-2 truncate shrink-0">
                NULL
              </h3>
              <p class="font-body text-sm text-frost/40 leading-relaxed line-clamp-2 overflow-hidden min-h-0">
                NULL
              </p>
            </div>
          )}
        </div>
      </section>

      <!-- Outsourcing -->
      <section class="flex flex-col">
        <div class="flex items-center justify-between mb-6 shrink-0">
          <h2 class="font-mono text-xs tracking-[0.2em] uppercase text-frost">
            <span class="text-neon-cyan">$</span> ls outsourcing/ --reverse
          </h2>
          <a href={`${base}/outsourcing`} class="font-mono text-xs text-frost hover:text-plasma transition-colors duration-200">
            View all &rarr;
          </a>
        </div>
        <div class="flex-1 flex flex-col gap-4 min-h-0">
          {outsourcingCards.length > 0 ? (
            outsourcingCards.map((card) => (
              <MagneticCard class="glass-card flex-1">
                <a href={card.link} class="group block p-6 h-full flex flex-col">
                  <p class="font-mono text-xs text-frost/50 mb-3 shrink-0">
                    created {card.created} / updated {card.updated}
                  </p>
                  <h3 class="font-display text-lg font-bold text-plasma mb-2 group-hover:text-neon-cyan transition-colors duration-200 truncate shrink-0">
                    {card.title}
                  </h3>
                  <p class="font-body text-sm text-frost leading-relaxed line-clamp-2 overflow-hidden min-h-0">
                    {card.description}
                  </p>
                </a>
              </MagneticCard>
            ))
          ) : (
            <div class="glass-card p-6 h-full flex flex-col">
              <p class="font-mono text-xs text-frost/50 mb-3 shrink-0">
                created NULL / updated NULL
              </p>
              <h3 class="font-display text-lg font-bold text-frost/40 mb-2 truncate shrink-0">
                NULL
              </h3>
              <p class="font-body text-sm text-frost/40 leading-relaxed line-clamp-2 overflow-hidden min-h-0">
                NULL
              </p>
            </div>
          )}
        </div>
      </section>

    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  (function() {
    var el = document.getElementById('typewriter');
    if (!el) return;
    var texts = [
      '$ whoami',
      '$ cat /etc/motd',
      '$ echo $USER',
      '$ uname -a',
    ];
    var i = 0;
    var j = 0;
    var typing = true;
    var pauseEnd = 0;

    function tick() {
      var now = Date.now();
      if (!typing && now < pauseEnd) {
        requestAnimationFrame(tick);
        return;
      }

      var current = texts[i % texts.length];

      if (typing) {
        if (j <= current.length) {
          el.textContent = current.substring(0, j);
          j++;
          setTimeout(tick, 60 + Math.random() * 40);
          return;
        }
        typing = false;
        pauseEnd = now + 2000;
        requestAnimationFrame(tick);
      } else {
        if (j > 0) {
          j--;
          el.textContent = current.substring(0, j);
          setTimeout(tick, 25 + Math.random() * 20);
          return;
        }
        typing = true;
        i++;
        j = 0;
        setTimeout(tick, 150);
      }
    }

    tick();
  })();
</script>
