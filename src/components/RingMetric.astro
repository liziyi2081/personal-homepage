---
// RingMetric.astro — SVG ring progress indicator
export interface Props {
  value: number;
  max: number;
  label: string;
  unit?: string;
}

const { value, max, label, unit = '' } = Astro.props;
const ratio = Math.min(value / Math.max(max, 1), 1);
const circumference = 2 * Math.PI * 38; // r=38
const offset = circumference * (1 - ratio);
const id = `ring-${label.replace(/\s+/g, '-')}`;
---

<div class="flex flex-col items-center gap-2">
  <svg viewBox="0 0 100 100" class="w-16 h-16 md:w-20 md:h-20" id={id}>
    <circle
      cx="50" cy="50" r="38"
      fill="none"
      stroke="rgba(255,255,255,0.06)"
      stroke-width="4"
    />
    <circle
      cx="50" cy="50" r="38"
      fill="none"
      stroke="url(#{id}-gradient)"
      stroke-width="4"
      stroke-linecap="round"
      stroke-dasharray={circumference}
      stroke-dashoffset={offset}
      transform="rotate(-90 50 50)"
      class="ring-progress transition-all duration-1000 ease-out"
    />
    <defs>
      <linearGradient id="{id}-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#00e5ff" />
        <stop offset="100%" stop-color="#a855f7" />
      </linearGradient>
    </defs>
    <text
      x="50" y="50"
      text-anchor="middle"
      dominant-baseline="central"
      fill="white"
      font-family="'Space Grotesk', sans-serif"
      font-size="16"
      font-weight="700"
    >{value}{unit}</text>
  </svg>
  <span class="font-mono text-[10px] tracking-wider uppercase text-frost/50">{label}</span>
</div>

<script>
  // Animate rings on visible
  const el = document.getElementById('{id}');
  if (el) {
    const observer = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const ring = el.querySelector('.ring-progress');
          if (ring) {
            ring.setAttribute('stroke-dashoffset', '{offset}');
          }
          observer.unobserve(el);
        }
      }
    }, { threshold: 0.5 });
    observer.observe(el);
  }
</script>

<style is:global>
  .ring-progress {
    transition: stroke-dashoffset 1.2s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>
