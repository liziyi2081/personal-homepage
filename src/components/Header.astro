---
import { SITE_TITLE } from '../consts';

const navLinks = [
  { href: '/articles', label: 'Articles' },
  { href: '/products', label: 'Products' },
  { href: '/projects', label: 'Projects' },
];
---

<header class="flex items-center justify-between py-6 px-6 lg:px-12 max-w-6xl mx-auto">
  <a href="/" class="font-display text-lg font-bold text-parchment tracking-tight hover:text-forge-orange transition-colors duration-200">
    {SITE_TITLE}
  </a>
  <nav class="flex gap-6" aria-label="Main navigation">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="font-mono text-xs tracking-wider uppercase text-stone hover:text-parchment transition-colors duration-200"
      >
        {link.label}
      </a>
    ))}
  </nav>
</header>
