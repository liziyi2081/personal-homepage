  <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
    <div class="flex gap-6">
      <a href="https://github.com/liziyi" class="font-mono text-xs text-stone hover:text-parchment transition-colors duration-200">
        GitHub
      </a>
      <a href="mailto:liziyi@example.com" class="font-mono text-xs text-stone hover:text-parchment transition-colors duration-200">
        Email
      </a>
    </div>
    <p class="font-mono text-xs text-stone/60">
      &copy; {currentYear} Built with Astro &amp; shipped from GitHub
    </p>
  </div>
</footer>
