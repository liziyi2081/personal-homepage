---
// MagneticCard.astro — Card wrapper with mouse-driven 3D tilt
const { class: className = '' } = Astro.props;
---
<div
  class={`magnetic-card ${className}`}
  style="perspective: 800px;"
>
  <div class="magnetic-inner">
    <slot />
  </div>
</div>

<script>
  function initMagneticCards() {
    const cards = document.querySelectorAll('.magnetic-card') as NodeListOf<HTMLElement>;
    if (cards.length === 0) return;

    const isMobile = window.matchMedia('(max-width: 767px)').matches;
    if (isMobile) return;

    for (const card of cards) {
      const inner = card.querySelector('.magnetic-inner') as HTMLElement;
      if (!inner) continue;

      card.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        inner.style.transform = `rotateY(${x * 5}deg) rotateX(${-y * 5}deg)`;
      });

      card.addEventListener('mouseleave', () => {
        inner.style.transform = 'rotateY(0deg) rotateX(0deg)';
        inner.style.transition = 'transform 400ms ease';
      });

      card.addEventListener('mouseenter', () => {
        inner.style.transition = 'transform 100ms ease';
      });
    }
  }

  initMagneticCards();
  document.addEventListener('astro:page-load', initMagneticCards);
</script>

<style is:global>
  .magnetic-card {
    display: block;
  }

  .magnetic-inner {
    transform-style: preserve-3d;
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .magnetic-inner {
      transform: none !important;
      transition: none !important;
    }
  }
</style>
